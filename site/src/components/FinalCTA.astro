---
import CopyButton from './CopyButton.tsx';
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <div class="absolute inset-0 bg-gradient-to-b from-surface/50 to-transparent" />

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold sm:text-4xl">Ready to migrate?</h2>
    <p class="mt-4 text-lg text-muted">
      Install in seconds, dry-run for free, migrate with confidence.
    </p>

    <!-- Install command -->
    <div class="relative mx-auto mt-8 max-w-md">
      <pre class="rounded-lg bg-code px-6 py-4 pr-12 text-left font-mono text-sm text-[#E8E6E3]"><code>pip install slack-chat-migrator</code></pre>
      <CopyButton text="pip install slack-chat-migrator" client:visible />
    </div>

    <!-- Buttons -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="https://github.com/nicklamont/slack-chat-migrator"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 font-medium text-accent-contrast shadow-lg shadow-accent/25 transition-all hover:bg-accent/90 hover:shadow-xl"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        View on GitHub
      </a>
      <a
        href="https://pypi.org/project/slack-chat-migrator/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 font-medium text-text transition-all hover:border-secondary hover:text-secondary"
      >
        View on PyPI
      </a>
    </div>
  </div>
</section>
