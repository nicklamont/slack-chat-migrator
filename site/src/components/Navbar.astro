---
import ThemeToggle from './ThemeToggle.tsx';

const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Quick Start', href: '#quick-start' },
  { label: 'FAQ', href: '#faq' },
];
---

<nav
  class="fixed top-0 z-50 w-full border-b border-border bg-bg/80 backdrop-blur-md"
  id="navbar"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2 font-mono text-sm font-semibold text-accent">
      <img src={`${import.meta.env.BASE_URL}/favicon.svg`} alt="" class="h-6 w-6" />
      slack-chat-migrator
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-6 md:flex">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-muted transition-colors hover:text-text"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/nicklamont/slack-chat-migrator"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted transition-colors hover:text-text"
        aria-label="GitHub repository"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>
      <ThemeToggle client:load />
    </div>

    <!-- Mobile menu button -->
    <button
      class="md:hidden text-muted"
      id="mobile-menu-btn"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" id="hamburger-icon" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" id="close-icon" class="hidden" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="hidden md:hidden border-t border-border" id="mobile-menu">
    <div class="space-y-1 px-4 py-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-link block rounded-lg px-3 py-2 text-sm text-muted transition-colors hover:bg-surface hover:text-text"
        >
          {link.label}
        </a>
      ))}
      <div class="flex items-center justify-between px-3 py-2">
        <a
          href="https://github.com/nicklamont/slack-chat-migrator"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted hover:text-text"
        >
          GitHub
        </a>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
